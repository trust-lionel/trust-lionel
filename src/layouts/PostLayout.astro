---
// src/layouts/PostLayout.astro
// Layout for individual blog posts at /blog/[slug].
// Responsibilities:
//   - Wraps BaseLayout with article-specific head meta (OG, Twitter, JSON-LD Article schema)
//   - Renders the Nav component
//   - Post header: title, description, author + date metadata, tag pills
//   - Markdown body slot
//   - Footer component

import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import TagPill from '../components/TagPill.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  date: Date;
  author?: string;
  tags?: string[];
  og_image?: string;
  slug: string;
}

const {
  title,
  description,
  date,
  author = 'Lionel Mosley',
  tags = [],
  og_image,
  slug,
} = Astro.props;

const canonicalURL = new URL(`/blog/${slug}`, Astro.site).href;
const resolvedOgImage = og_image ?? `/og/${slug}.png`;

// Format date for display and schema
const displayDate = date.toLocaleDateString('en-US', {
  year: 'numeric', timeZone: 'UTC',
  month: 'long',
  day: 'numeric',
});

const isoDate = date.toISOString();

// JSON-LD Article structured data
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  datePublished: isoDate,
  author: {
    '@type': 'Person',
    name: author,
    url: 'https://trust-lionel.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'ahr-ki-tekt',
    url: 'https://trust-lionel.com',
  },
  url: canonicalURL,
  image: new URL(resolvedOgImage, Astro.site).href,
  keywords: tags.join(', '),
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalURL={canonicalURL}
  ogImage={resolvedOgImage}
  ogType="article"
  articleDate={date}
  articleAuthor={author}
  articleTags={tags}
>
  <!-- JSON-LD structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <Nav />

  <main id="main-content">
    <article class="post-article" aria-labelledby="post-title">

      <!-- Post header zone -->
      <header class="post-header">
        <div class="post-header-inner">

          {tags.length > 0 && (
            <div class="post-header-tags" aria-label="Post categories">
              {tags.map(tag => <TagPill tag={tag} />)}
            </div>
          )}

          <h1 class="post-title" id="post-title">{title}</h1>

          <p class="post-description">{description}</p>

          <div class="post-meta" aria-label="Post metadata">
            <div class="post-meta-col">
              <span class="post-meta-label">Written by</span>
              <span class="post-meta-value">{author}</span>
            </div>
            <div class="post-meta-divider" aria-hidden="true"></div>
            <div class="post-meta-col">
              <span class="post-meta-label">Published on</span>
              <time class="post-meta-value" datetime={isoDate}>{displayDate}</time>
            </div>
          </div>

        </div>
      </header>

      <!-- Post body — rendered Markdown -->
      <div class="post-body">
        <div class="post-prose">
          <slot />
        </div>
      </div>

    </article>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* ── POST HEADER ── */
  .post-header {
    background: var(--color-bg-header);
    position: relative;
    overflow: hidden;
    padding: 4rem 2rem 3rem;
    border-bottom: 1px solid var(--color-border);
  }

  /* Dot-grid texture matching the index page header */
  .post-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--grid-color) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-color) 1px, transparent 1px);
    background-size: 32px 32px;
    pointer-events: none;
  }

  .post-header-inner {
    max-width: 760px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .post-header-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .post-title {
    font-family: var(--font-sans);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    margin-bottom: 1rem;
  }

  .post-description {
    font-size: 18px;
    font-weight: 300;
    color: var(--color-text-secondary);
    line-height: 1.65;
    max-width: 680px;
    margin-bottom: 2rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .post-meta-col {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 0 1.5rem;
  }

  .post-meta-col:first-child {
    padding-left: 0;
  }

  .post-meta-divider {
    width: 1px;
    height: 36px;
    background: var(--color-border-strong);
    flex-shrink: 0;
  }

  .post-meta-label {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .post-meta-value {
    font-size: 14px;
    font-weight: 400;
    color: var(--color-text-primary);
  }

  /* ── POST BODY ── */
  .post-body {
    padding: 4rem 2rem;
  }

  .post-prose {
    max-width: 760px;
    margin: 0 auto;
  }

  /* Prose typography — applied to Markdown-rendered content */
  .post-prose :global(h2) {
    font-family: var(--font-sans);
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.015em;
    color: var(--color-text-primary);
    margin: 2.5rem 0 1rem;
  }

  .post-prose :global(h3) {
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-text-primary);
    margin: 2rem 0 0.75rem;
  }

  .post-prose :global(h4) {
    font-family: var(--font-sans);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 1.75rem 0 0.5rem;
  }

  .post-prose :global(p) {
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin-bottom: 1.25rem;
  }

  .post-prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--color-accent) 40%, transparent);
    text-underline-offset: 3px;
    transition: text-decoration-color var(--transition);
  }

  .post-prose :global(a:hover) {
    text-decoration-color: var(--color-accent);
  }

  .post-prose :global(ul),
  .post-prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .post-prose :global(li) {
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin-bottom: 0.375rem;
  }

  .post-prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1.25rem;
    margin: 1.75rem 0;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .post-prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 1px 6px;
    color: var(--color-text-primary);
  }

  .post-prose :global(pre) {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .post-prose :global(pre code) {
    background: transparent;
    border: none;
    padding: 0;
    font-size: 14px;
    line-height: 1.65;
  }

  .post-prose :global(img) {
    border-radius: var(--radius-md);
    margin: 2rem auto;
    border: 1px solid var(--color-border);
  }

  .post-prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 3rem 0;
  }

  .post-prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 14px;
  }

  .post-prose :global(th) {
    text-align: left;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    border-bottom: 2px solid var(--color-border);
    padding: 0.5rem 0.75rem;
  }

  .post-prose :global(td) {
    padding: 0.625rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    vertical-align: top;
  }

  .post-prose :global(tr:last-child td) {
    border-bottom: none;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .post-header {
      padding: 2.5rem 1.25rem 2rem;
    }

    .post-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .post-meta-divider {
      display: none;
    }

    .post-meta-col {
      padding: 0;
    }

    .post-body {
      padding: 2.5rem 1.25rem;
    }
  }
</style>
