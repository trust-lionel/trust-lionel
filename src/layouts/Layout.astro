---
import '~/styles/global.css'
import '~/styles/markdown.css'
import '~/styles/lqip.css'
import '~/styles/github-card.css'
import { SITE } from '~/config'
import Head from '~/components/base/Head.astro'
import Header from './Header.astro'
import Footer from './Footer.astro'

type Props = {
  title: string
  description: string
  image?: string
  disableViewTransition?: boolean
  blogPosting?: {
    headline: string
    description: string
    datePublished: string
    url: string
    image: string
    keywords: string[]
  }
}

const { title, description, image, disableViewTransition, blogPosting }: Props = Astro.props
---

<!doctype html>
<html lang={SITE.lang} transition:name="root" transition:animate={SITE.transition && !disableViewTransition ? 'fade' : 'none'}>
  <head>
    <Head title={title ? `${title} | ${SITE.title}` : SITE.title} {description} {image} />
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-543DS8T7');</script>
    <!-- End Google Tag Manager -->
    <!-- Umami Analytics — cookieless, GDPR-compliant, self-hosted on Railway -->
    <script is:inline defer src="https://umami-production-f3f3.up.railway.app/script.js" data-website-id="b8e2a312-e7f4-4595-95ee-38b47fc9be54"></script>
    <!-- Person + WebSite JSON-LD Structured Data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Lionel Mosley",
      "url": "https://trust-lionel.com",
      "image": "https://trust-lionel.com/og-image.png",
      "jobTitle": "IT Consultant & Innovative Thought Leader",
      "description": "IT Consultant, Cloud Engineer, Innovative Thought Leader, and Subject Matter Expert specializing in cloud infrastructure, cybersecurity, Microsoft 365, and enterprise IT governance. Based in Houston, TX — serving organizations nationwide through 4TH AND BAILEY.",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Houston",
        "addressRegion": "TX",
        "addressCountry": "US"
      },
      "worksFor": {
        "@type": "Organization",
        "name": "4TH AND BAILEY",
        "url": "https://4thandbailey.com"
      },
      "sameAs": [
        "https://trust-lionel.com",
        "https://linkedin.com/in/lionelmosley",
        "https://github.com/trust-lionel",
        "https://youtube.com/@LMosley002",
        "https://x.com/lionelmosley",
        "https://www.facebook.com/yourinfotechconsultant",
        "https://www.threads.com/@lionelmosley",
        "https://bsky.app/profile/lionelmosley",
        "https://instagram.com/lionelmosley",
        "https://reddit.com/u/trust-lionel",
        "https://open.spotify.com/user/lmosley002-spotify",
        "https://about.me/lionelmosley",
        "https://blog.lionelmosley.com",
        "https://devops.houstonalert.com",
        "https://wordcards.co"
      ],
      "knowsAbout": [
        "Cloud Infrastructure","Cloud Engineering","Cybersecurity","Microsoft 365",
        "Microsoft Azure","Amazon AWS","Google Workspace","Cloud Migration",
        "Cloud Repatriation","CISA SCuBA","NIST SP 800-53","MITRE ATT&CK",
        "CIS Benchmarks","HIPAA Compliance","CMMC","PCI-DSS",
        "Enterprise IT Governance","IT Consulting","Incident Response",
        "AI Governance","Business Continuity"
      ],
      "hasCredential": [
        {
          "@type": "EducationalOccupationalCredential",
          "name": "Microsoft Cloud Solution Provider (CSP)",
          "credentialCategory": "Professional Certification",
          "recognizedBy": { "@type": "Organization", "name": "Microsoft", "url": "https://www.microsoft.com" }
        },
        {
          "@type": "EducationalOccupationalCredential",
          "name": "Google Partner",
          "credentialCategory": "Professional Certification",
          "recognizedBy": { "@type": "Organization", "name": "Google", "url": "https://www.google.com" }
        }
      ],
      "author": [
        {
          "@type": "TechArticle",
          "name": "How We Built Houston Alert — A Real-Time City Warning System",
          "url": "https://devops.houstonalert.com",
          "datePublished": "2026-04-15",
          "publisher": { "@type": "Organization", "name": "4th and Bailey LLC", "url": "https://4thandbailey.com" }
        }
      ],
      "maintainer": [
        {
          "@type": "SoftwareSourceCode",
          "name": "Infrastructure Placement Framework",
          "url": "https://framework.4thandbailey.com",
          "codeRepository": "https://github.com/4thandBailey/infrastructure-placement-framework",
          "license": "https://creativecommons.org/licenses/by/4.0/"
        },
        {
          "@type": "SoftwareApplication",
          "name": "Houston Alert",
          "url": "https://houstonalert.com",
          "applicationCategory": "PublicSafetyApplication",
          "operatingSystem": "Web, PWA"
        },
        {
          "@type": "SoftwareSourceCode",
          "name": "Shopify \u2194 Sage BusinessWorks Middleware Agent",
          "url": "https://github.com/4thandBailey/shopify-bw-agent",
          "codeRepository": "https://github.com/4thandBailey/shopify-bw-agent"
        },
        {
          "@type": "SoftwareSourceCode",
          "name": "Microsoft 365 PowerShell Tools",
          "url": "https://github.com/4thandBailey/tools",
          "codeRepository": "https://github.com/4thandBailey/tools"
        },
        {
          "@type": "WebApplication",
          "name": "W.O.R.D. — Written Or Received Daily",
          "url": "https://wordcards.co",
          "applicationCategory": "LifestyleApplication",
          "description": "A motivational postcard web application — draw or send a good word to someone who needs it."
        },
        {
          "@type": "WebSite",
          "name": "M365CloudPro",
          "url": "https://m365cloudpro.com",
          "description": "Self-service Microsoft 365 licensing storefront powered by 4TH AND BAILEY."
        }
      ]
    })} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Lionel Mosley | ahr-ki-tekt",
      "url": "https://trust-lionel.com",
      "description": "Carefully selected frameworks, insights, and solutions from Lionel Mosley — IT Consultant & Innovative Thought Leader based in Houston, TX.",
      "author": { "@type": "Person", "name": "Lionel Mosley", "url": "https://trust-lionel.com" },
      "inLanguage": "en-US"
    })} />
    <!-- BlogPosting JSON-LD — injected on post pages only -->
    {blogPosting && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": blogPosting.headline,
        "description": blogPosting.description,
        "author": { "@type": "Person", "name": "Lionel Mosley", "url": "https://trust-lionel.com" },
        "publisher": { "@type": "Organization", "name": "Lionel Mosley | ahr-ki-tekt", "url": "https://trust-lionel.com" },
        "datePublished": blogPosting.datePublished,
        "url": blogPosting.url,
        "image": blogPosting.image,
        "keywords": blogPosting.keywords
    })} />
    )}
  </head>
  <body class="flex flex-col">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-543DS8T7" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <Header />
    <div class="grow flex">
      <main class="relative border-x border-border/50 global-layout-width mx-auto grow min-w-0">
        <slot />
      </main>
    </div>
    <Footer />
    <div
      class="safari-hidden pointer-events-none bg-white dark:bg-black fixed z-50 bottom-0 left-0 h-28 [mask-image:linear-gradient(transparent,#000000)] w-full"
    >
    </div>
  </body>
</html>
