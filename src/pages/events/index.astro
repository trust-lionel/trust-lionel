---
import Layout from '~/layouts/Layout.astro'
import SectionDivider from '~/components/base/SectionDivider.astro'
import { getCollection } from 'astro:content'

const allEvents = await getCollection('events')

// Sort: upcoming first by date ascending, then past events by date descending
const upcomingEvents = allEvents
  .filter((e) => e.data.eventStatus === 'upcoming')
  .sort((a, b) => a.data.eventDate.getTime() - b.data.eventDate.getTime())

const pastEvents = allEvents
  .filter((e) => e.data.eventStatus === 'past')
  .sort((a, b) => b.data.eventDate.getTime() - a.data.eventDate.getTime())

const events = [...upcomingEvents, ...pastEvents]

function formatEventDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    weekday: 'long',
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  })
}
---

<Layout title="Events" description="Speaking engagements, workshops, and live sessions led by Lionel Mosley — IT Consultant and Innovative Thought Leader.">
  <div class="relative z-[1]">
    <div class="py-8 pb-10 px-6 sm:px-8">
      <h1 class="text-4xl sm:text-5xl tracking-tight mb-2">Events</h1>
      <p class="text-muted-foreground text-lg font-light">
        Speaking engagements, workshops, and live sessions.
      </p>
    </div>

    <SectionDivider />

    <div class="py-8 pb-10 px-6 sm:px-8">
      {upcomingEvents.length > 0 && (
        <div class="mb-10">
          <h2 class="text-sm font-semibold uppercase tracking-widest text-muted-foreground mb-6">Upcoming</h2>
          <div class="grid gap-4 sm:grid-cols-1 lg:grid-cols-2">
            {upcomingEvents.map((event) => (
              <a
                href={`/events/${event.id}`}
                class="group block border border-border/60 rounded-lg p-6 hover:border-primary/40 hover:bg-accent/20 transition-all duration-200"
              >
                <div class="flex items-center gap-2 mb-3">
                  <span class="inline-flex items-center gap-1.5 text-xs font-semibold px-2.5 py-1 rounded-full bg-primary/10 text-primary">
                    <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
                    Upcoming
                  </span>
                  <span class="text-xs text-muted-foreground">{event.data.eventFormat}</span>
                </div>
                <h3 class="text-base font-semibold text-foreground group-hover:text-primary transition-colors leading-snug mb-2">
                  {event.data.title}
                </h3>
                <p class="text-sm text-muted-foreground leading-relaxed mb-4 line-clamp-2">
                  {event.data.description}
                </p>
                <div class="flex flex-col gap-1 text-xs text-muted-foreground border-t border-border/40 pt-3 mt-3">
                  <span class="flex items-center gap-2">
                    <span class="icon-[material-symbols--calendar-month] size-3.5"></span>
                    {formatEventDate(event.data.eventDate)}
                  </span>
                  <span class="flex items-center gap-2">
                    <span class="icon-[material-symbols--schedule] size-3.5"></span>
                    {event.data.eventTime}
                  </span>
                  <span class="flex items-center gap-2">
                    <span class="icon-[material-symbols--location-on] size-3.5"></span>
                    {event.data.eventHost}
                  </span>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      {pastEvents.length > 0 && (
        <div>
          <h2 class="text-sm font-semibold uppercase tracking-widest text-muted-foreground mb-6">Past Events</h2>
          <div class="grid gap-4 sm:grid-cols-1 lg:grid-cols-2">
            {pastEvents.map((event) => (
              <a
                href={`/events/${event.id}`}
                class="group block border border-border/40 rounded-lg p-6 hover:border-border hover:bg-accent/10 transition-all duration-200 opacity-75 hover:opacity-100"
              >
                <div class="flex items-center gap-2 mb-3">
                  <span class="inline-flex items-center gap-1.5 text-xs font-semibold px-2.5 py-1 rounded-full bg-muted text-muted-foreground">
                    Past
                  </span>
                  <span class="text-xs text-muted-foreground">{event.data.eventFormat}</span>
                </div>
                <h3 class="text-base font-semibold text-foreground group-hover:text-primary transition-colors leading-snug mb-2">
                  {event.data.title}
                </h3>
                <p class="text-sm text-muted-foreground leading-relaxed mb-4 line-clamp-2">
                  {event.data.description}
                </p>
                <div class="flex flex-col gap-1 text-xs text-muted-foreground border-t border-border/40 pt-3 mt-3">
                  <span class="flex items-center gap-2">
                    <span class="icon-[material-symbols--calendar-month] size-3.5"></span>
                    {formatEventDate(event.data.eventDate)}
                  </span>
                  <span class="flex items-center gap-2">
                    <span class="icon-[material-symbols--schedule] size-3.5"></span>
                    {event.data.eventTime}
                  </span>
                  <span class="flex items-center gap-2">
                    <span class="icon-[material-symbols--location-on] size-3.5"></span>
                    {event.data.eventHost}
                  </span>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      {events.length === 0 && (
        <div class="text-center py-16 text-muted-foreground">
          <p class="text-lg">No events scheduled at this time.</p>
          <p class="text-sm mt-2">Check back soon or <a href="/consulting" class="underline hover:text-foreground">schedule a consultation</a>.</p>
        </div>
      )}
    </div>
  </div>
</Layout>
