---
/**
 * SpotifyEmbed.astro
 * Renders a Spotify playlist embed at the bottom of a post.
 * Usage: pass spotifyPlaylistId from post frontmatter.
 * The playlist ID is the alphanumeric string from the Spotify share link:
 *   https://open.spotify.com/playlist/{spotifyPlaylistId}
 */

interface Props {
  playlistId: string
  title?: string
}

const { playlistId, title = 'Playlist' } = Astro.props
const embedUrl = `https://open.spotify.com/embed/playlist/${playlistId}?utm_source=generator&theme=0`
---

<div class="spotify-embed mt-8">
  <p class="text-xs font-medium text-muted-foreground uppercase tracking-widest mb-3">
    What Was Playing
  </p>
  <iframe
    src={embedUrl}
    width="100%"
    height="352"
    frameborder="0"
    allowfullscreen
    allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
    loading="lazy"
    title={`Spotify Playlist — ${title}`}
    style="border-radius: 12px;"
  ></iframe>
</div>
